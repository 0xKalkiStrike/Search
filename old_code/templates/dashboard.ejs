<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Processing Data | Search Scraper</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <div class="container" style="max-width: 900px; margin: 3rem auto; padding: 0 1rem;">
        <div class="glass-card">
            <h1 style="margin-top:0">Processing Dataset</h1>
            <p style="color: var(--text-muted)">We are searching and scraping <span id="total-count"><%= count %></span> names from your file.</p>
            
            <div class="stats-card">
                <div class="stat-box">
                    <span class="stat-value" id="stat-processed">0</span>
                    <span class="stat-label">Processed</span>
                </div>
                <div class="stat-box">
                    <span class="stat-value" id="stat-emails">0</span>
                    <span class="stat-label">Emails Found</span>
                </div>
                <div class="stat-box">
                    <span class="stat-value" id="stat-phones">0</span>
                    <span class="stat-label">Phones Found</span>
                </div>
            </div>

            <div class="progress-container">
                <div class="progress-bar" id="main-progress"></div>
            </div>
            
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem">
                <span id="status-text" style="font-weight: 600">Initializing...</span>
                <span id="progress-percent">0%</span>
            </div>

            <h3 style="margin-top: 2rem">Activity Log</h3>
            <div class="feed" id="log-feed">
                <div class="feed-item info">Workers connected. Starting search...</div>
            </div>

            <div style="margin-top: 2rem; display: none; gap: 1rem;" id="complete-actions">
                <a href="/download" class="btn-premium" style="text-decoration: none; background: linear-gradient(135deg, #10b981, #059669);">📥 Save as Excel</a>
                <a href="/results" class="btn-premium" style="text-decoration: none">View Detailed Results</a>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const total = <%= count %>;
        let processed = 0;
        let emailsFound = 0;
        let phonesFound = 0;

        const logFeed = document.getElementById('log-feed');
        const progressBar = document.getElementById('main-progress');
        const progressPercent = document.getElementById('progress-percent');
        const statusText = document.getElementById('status-text');
        const statProcessed = document.getElementById('stat-processed');
        const statEmails = document.getElementById('stat-emails');
        const statPhones = document.getElementById('stat-phones');
        const completeActions = document.getElementById('complete-actions');

        function addLog(message, type = 'info') {
            const item = document.createElement('div');
            item.className = `feed-item ${type}`;
            item.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
            logFeed.prepend(item);
        }

        socket.on('status', (data) => {
            statusText.textContent = data.message;
            const p = Math.min(data.progress, 100);
            progressBar.style.width = p + '%';
            progressPercent.textContent = p + '%';
            addLog(`Status: ${data.message}`);
        });

        socket.on('result', (data) => {
            processed++;
            statProcessed.textContent = processed;
            
            if (data.emails && data.emails.length > 0) {
                emailsFound += data.emails.length;
                statEmails.textContent = emailsFound;
            }
            if (data.phones && data.phones.length > 0) {
                phonesFound += data.phones.length;
                statPhones.textContent = phonesFound;
            }

            addLog(`Found ${data.emails.length} emails and ${data.phones.length} phones for "${data.name}"`, 'success');
        });

        socket.on('complete', (data) => {
            progressBar.style.width = '100%';
            progressPercent.textContent = '100%';
            statusText.textContent = 'Processing Complete!';
            addLog('Batch processing finished successfully.', 'success');
            completeActions.style.display = 'block';
        });

        socket.on('error', (data) => {
            addLog(`Error: ${data.message}`, 'error');
            statusText.textContent = 'Error occurred during processing.';
            statusText.style.color = '#f87171';
        });
    </script>
</body>
</html>
