<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Results | Data Scraper Pro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <div class="container" style="max-width: 1000px; margin: 3rem auto; padding: 0 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap;">
            <h1 style="margin: 0">Extraction Results</h1>
            <div style="display: flex; gap: 1rem;">
                <a href="/download" class="btn-premium" style="text-decoration: none; background: linear-gradient(135deg, #10b981, #059669);">📥 Save as Excel</a>
                <a href="/" class="btn-premium" style="text-decoration: none">New Extraction</a>
            </div>
        </div>

        <% for (let name in results) { %>
            <div class="glass-card" style="margin-bottom: 2rem; padding: 1.5rem;">
                <h3 style="margin-top: 0; color: var(--primary);"><%= name %></h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem;">
                    <div>
                        <div class="stat-label" style="margin-bottom: 0.5rem">Phones</div>
                        <% if (results[name].phones && results[name].phones.length > 0) { %>
                            <% results[name].phones.forEach(function(phone) { %>
                                <div style="background: rgba(52, 211, 153, 0.1); padding: 0.5rem; border-radius: 0.4rem; margin-bottom: 0.5rem; font-family: 'JetBrains Mono'">
                                    📞 <%= phone %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div style="color: var(--text-muted); font-style: italic">No phones found</div>
                        <% } %>
                    </div>

                    <div>
                        <div class="stat-label" style="margin-bottom: 0.5rem">Emails</div>
                        <% if (results[name].emails && results[name].emails.length > 0) { %>
                            <% results[name].emails.forEach(function(email) { %>
                                <div style="background: rgba(99, 102, 241, 0.1); padding: 0.5rem; border-radius: 0.4rem; margin-bottom: 0.5rem; font-family: 'JetBrains Mono'">
                                    📧 <%= email %>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div style="color: var(--text-muted); font-style: italic">No emails found</div>
                        <% } %>
                    </div>
                </div>

                <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border);">
                    <div class="stat-label" style="margin-bottom: 0.5rem">Sources</div>
                    <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                        <% results[name].sources.forEach(function(source) { %>
                            <a href="<%= source %>" target="_blank" style="color: var(--text-muted); text-decoration: none; font-size: 0.8rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                🔗 <%= source %>
                            </a>
                        <% }); %>
                    </div>
                </div>
            </div>
        <% } %>
    </div>
</body>
</html>